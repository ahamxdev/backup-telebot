# =============================================================================
# Telegram Backup Sender Bot — environment variables
# Copy this file to .env, fill in the required values, then start the service.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# One or more chat IDs that will receive the backup files.
# Separate multiple values with commas, semicolons, or newlines.
# Use scripts/get_chat_id.py to discover IDs.
TELEGRAM_TARGET_CHAT_IDS=-1001234567890,-987654321

# Absolute path to the directory that will be watched for new backup files.
WATCH_DIR=/backup

# ── File selection ─────────────────────────────────────────────────────────────

# Shell glob pattern (relative to WATCH_DIR) for files to pick up.
# Examples: *.tar.gz   *.sql.gz   backup_*
# Default: * (all files)
FILE_GLOB=*

# Maximum file size in megabytes. Files larger than this are skipped with a warning.
# Note: the Telegram Bot API hard-limits sendDocument to ~50 MB.
# Default: 50
MAX_FILE_SIZE_MB=50

# ── Stability / timing ────────────────────────────────────────────────────────

# Seconds a file must remain unchanged (same size + mtime) before it is treated
# as fully written and ready to upload.
# Default: 20
STABLE_SECONDS=20

# Seconds to sleep between scan cycles when no file was processed.
# Default: 5
SCAN_INTERVAL=5

# Seconds to sleep after an unhandled exception before retrying.
# Default: 30
RETRY_BACKOFF=30

# How long (in seconds) a single HTTP request to Telegram may take.
# Large files benefit from a higher value.
# Default: 120
REQUEST_TIMEOUT=120

# ── Startup behaviour ─────────────────────────────────────────────────────────

# Set to true to upload files that already existed in WATCH_DIR when the bot starts.
# Default: false (pre-existing files are ignored on first start)
STARTUP_SEND_EXISTING=false

# Delete any pending webhook so the bot can use getUpdates (helper only).
# Default: true
CLEAR_WEBHOOK_ON_START=true

# ── Crash recovery ────────────────────────────────────────────────────────────

# If > 0, any .uploading file older than this many hours is considered abandoned
# and deleted on startup (instead of being retried). 0 = never auto-delete.
# Default: 0 (disabled)
DELETE_UPLOADING_OLDER_THAN_HOURS=0

# ── Concurrency guard ─────────────────────────────────────────────────────────

# Path to the exclusive lock file used to prevent two instances running at once.
# Default: /tmp/telegram-backup-bot.lock
LOCK_FILE=/tmp/telegram-backup-bot.lock

# ── Caption ───────────────────────────────────────────────────────────────────

# Python str.format() template for the Telegram message caption.
# Available variables: {filename}, {size_human}, {hostname}, {public_ip}
# Default (multi-line — use \n or a real newline):
# CAPTION_TEMPLATE=File: {filename}\nSize: {size_human}\nServer: {hostname}\nPublic IP: {public_ip}

# ── SOCKS proxy ───────────────────────────────────────────────────────────────

# Optional SOCKS proxy for ALL Telegram traffic (sendDocument, deleteWebhook, getUpdates).
# Use socks5h:// so DNS is resolved through the proxy (avoids DNS leaks).
# Requires 'requests[socks]' (PySocks) — already listed as a dependency.
# Examples:
#   SOCKS_PROXY=socks5h://127.0.0.1:1080
#   SOCKS_PROXY=socks5h://user:password@proxy.example.com:1080
# Leave empty for a direct connection (default).
SOCKS_PROXY=

# ── Custom Bot API server ─────────────────────────────────────────────────────

# Point at a local Telegram Bot API server to lift the ~50 MB file-size limit
# (a local server supports up to ~2 GB). Leave empty to use api.telegram.org.
# Example: TELEGRAM_API_BASE_URL=http://localhost:8081
TELEGRAM_API_BASE_URL=https://api.telegram.org

# ── Backup jobs ───────────────────────────────────────────────────────────────

# Path to a TOML job definition file. Leave empty to disable the jobs system.
# See scripts/sample_jobs.toml for examples.
BACKUP_JOBS_FILE=

# ── Admin notifications ───────────────────────────────────────────────────────

# Chat ID that receives job status notifications and alerts.
# Leave empty to disable admin notifications.
ADMIN_CHAT_ID=

# Send a heartbeat every N hours to confirm the service is alive. 0 = disabled.
HEARTBEAT_INTERVAL_HOURS=0

# Alert after N consecutive failures for a single job. 0 = disabled.
ALERT_CONSECUTIVE_FAILURES=3

# ── Pipeline defaults ─────────────────────────────────────────────────────────

# Default encryption tool: "age" or "gpg".
ENCRYPT_TOOL=age

# ── Two-way command interface (optional, SECURITY-CRITICAL) ───────────────────
#
# Setting TELEGRAM_ADMIN_CHAT_IDS enables the Telegram command interface.
# Only these whitelisted IDs can send commands. Any message from any other
# sender is silently dropped — no reply, no information leakage.
#
# SECURITY NOTES:
#   • Only jobs with manual_trigger = true in jobs.toml can be triggered.
#   • The command to execute always comes from jobs.toml on the server.
#     Telegram input can only select a job by name — NEVER supply a shell command.
#   • Leave TELEGRAM_ADMIN_CHAT_IDS empty (the default) to keep the bot
#     strictly one-way (no incoming command processing at all).
#
# How to find your user ID: send any message to your bot, then check
# scripts/get_chat_id.py output — your user ID will appear there.
#
# Format: comma-separated numeric IDs (use - prefix for groups/channels)
TELEGRAM_ADMIN_CHAT_IDS=

# Maximum commands a single admin can send per minute before being rate-limited.
# Default: 10
COMMAND_RATE_LIMIT=10
